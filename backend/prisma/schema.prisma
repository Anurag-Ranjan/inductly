generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum MemberRole {
  PRESIDENT
  VICE_PRESIDENT
  COORDINATOR
  MEMBER
  ADMIN
}

enum ApplicationStatus {
  PENDING
  SHORTLISTED
  REJECTED
  ACCEPTED
}

enum StageStatus {
  PENDING
  PASSED
  FAILED
}

enum QuestionType {
  TEXT
  TEXTAREA
  SELECT
  MULTI_SELECT
  CHECKBOX
  FILE
}

// ─────────────────────────────────────────────
// User & Auth
// ─────────────────────────────────────────────

model User {
  id    Int    @id @default(autoincrement())
  name  String
  email String @unique

  password          String?
  profile_picture   String?
  branch            String?
  batch             String?
  github            String?
  linkedin          String?
  mobile_number     String?
  isProfileComplete Boolean  @default(false)
  isVerified        Boolean  @default(false)
  isPictureUploaded Boolean  @default(false)
  refreshToken      String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  applications       Application[]
  memberships        Membership[]
  verificationTokens VerificationToken[]
  stageReviews       ApplicationStageProgress[] @relation("StageReviewer")
}

// Supports multiple token types per user (email verify + password reset)
model VerificationToken {
  id         Int       @id @default(autoincrement())
  token      String    @unique
  userId     Int
  type       TokenType @default(EMAIL_VERIFICATION)
  expires_at DateTime
  created_at DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────
// Club & Membership
// ─────────────────────────────────────────────

model Club {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  website     String?
  instagram   String?
  linkedin    String?
  logo        String?
  formed_on   DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  inductions  Induction[]
  memberships Membership[]
}

// Single source of truth for all club roles.
// Use role = PRESIDENT instead of a separate Club.president FK.
model Membership {
  id      Int        @id @default(autoincrement())
  user_id Int
  club_id Int
  role    MemberRole @default(MEMBER)
  // Kept for backwards compat — true when role is PRESIDENT/VP/COORDINATOR

  inducted_on DateTime?
  created_at  DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  club Club @relation(fields: [club_id], references: [id], onDelete: Cascade)

  @@unique([user_id, club_id])
  @@index([user_id])
  @@index([club_id])
}

// ─────────────────────────────────────────────
// Induction & Pipeline Stages
// ─────────────────────────────────────────────

model Induction {
  id          Int       @id @default(autoincrement())
  club_id     Int
  title       String
  description String?
  opened_on   DateTime?
  closing_on  DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  club         Club             @relation(fields: [club_id], references: [id], onDelete: Cascade)
  stages       InductionStage[]
  applications Application[]
  forms        Form[]

  @@index([club_id])
}

// Ordered pipeline steps for each induction (e.g. Screening → Interview → Task)
model InductionStage {
  id           Int      @id @default(autoincrement())
  induction_id Int
  name         String
  description  String?
  order_index  Int
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  induction           Induction                  @relation(fields: [induction_id], references: [id], onDelete: Cascade)
  progressList        ApplicationStageProgress[]
  currentApplications Application[]              @relation("CurrentStage")

  @@unique([induction_id, order_index])
  @@index([induction_id])
}

// ─────────────────────────────────────────────
// Applications & Stage Progress
// ─────────────────────────────────────────────

model Application {
  id               Int               @id @default(autoincrement())
  user_id          Int
  induction_id     Int
  current_stage_id Int?
  status           ApplicationStatus @default(PENDING)
  remarks          String?
  is_inducted      Boolean           @default(false)
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt

  user         User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  induction    Induction       @relation(fields: [induction_id], references: [id], onDelete: Cascade)
  currentStage InductionStage? @relation("CurrentStage", fields: [current_stage_id], references: [id])

  responses     FormResponse[]
  stageProgress ApplicationStageProgress[]

  @@unique([user_id, induction_id])
  @@index([user_id])
  @@index([induction_id])
  @@index([status])
  @@index([current_stage_id])
}

// Tracks each applicant's result at every pipeline stage
model ApplicationStageProgress {
  id             Int         @id @default(autoincrement())
  application_id Int
  stage_id       Int
  status         StageStatus @default(PENDING)
  score          Int?
  notes          String?
  reviewed_by    Int?
  reviewed_at    DateTime?
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt

  application Application    @relation(fields: [application_id], references: [id], onDelete: Cascade)
  stage       InductionStage @relation(fields: [stage_id], references: [id], onDelete: Cascade)
  reviewer    User?          @relation("StageReviewer", fields: [reviewed_by], references: [id], onDelete: SetNull)

  @@unique([application_id, stage_id])
  @@index([application_id])
  @@index([stage_id])
  @@index([reviewed_by])
  @@index([status])
}

// ─────────────────────────────────────────────
// Forms
// ─────────────────────────────────────────────

model Form {
  id           Int      @id @default(autoincrement())
  induction_id Int
  title        String
  description  String?
  created_at   DateTime @default(now())
  isPublished  Boolean

  induction Induction      @relation(fields: [induction_id], references: [id], onDelete: Cascade)
  questions FormQuestion[]
  responses FormResponse[]

  @@index([induction_id])
}

model FormQuestion {
  id            Int          @id @default(autoincrement())
  form_id       Int
  question_text String
  question_type QuestionType
  order_index   Int
  // Stores options for select/multi_select, validation rules, etc.
  metadata      Json?
  is_required   Boolean      @default(false)
  created_at    DateTime     @default(now())

  form    Form         @relation(fields: [form_id], references: [id], onDelete: Cascade)
  answers FormAnswer[]

  @@index([form_id])
  @@index([order_index])
}

model FormResponse {
  id             Int      @id @default(autoincrement())
  form_id        Int
  application_id Int
  submitted_at   DateTime @default(now())

  form        Form         @relation(fields: [form_id], references: [id], onDelete: Cascade)
  application Application  @relation(fields: [application_id], references: [id], onDelete: Cascade)
  answers     FormAnswer[]

  @@unique([form_id, application_id])
  @@index([form_id])
  @@index([application_id])
}

model FormAnswer {
  id          Int  @id @default(autoincrement())
  response_id Int
  question_id Int
  answer      Json

  response FormResponse @relation(fields: [response_id], references: [id], onDelete: Cascade)
  question FormQuestion @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@index([response_id])
  @@index([question_id])
}
